{
  "name": "midnight-hospital-mvp",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && tsc -p tsconfig.server.json && vite build",
    "build:pages": "VITE_DISABLE_STORY_API=true npm run build",
    "start": "node dist-server/server/productionServer.js",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run",
    "test:watch": "vitest",
    "sim:difficulty": "tsx src/scripts/runDifficultySimulator.ts",
    "check:prod": "tsx src/scripts/checkProductionReadiness.ts",
    "verify:prod": "npm test && npm run build && npm run check:prod && npm run sim:difficulty -- --runs=10000",
    "verify:pages": "npm test && npm run build:pages && npm run check:prod"
  },
  "dependencies": {
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "5.2.0",
    "@types/node": "24.13.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "tsx": "4.22.4",
    "typescript": "5.9.3",
    "vite": "7.3.6",
    "vitest": "4.1.9"
  }
}
